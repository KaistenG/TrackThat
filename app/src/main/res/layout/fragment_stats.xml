<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/cardCurrentMonth"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="12dp"
        android:background="#FFEEEEEE"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:text="📅 Aktueller Monat"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/cardAverage"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="12dp"
        android:background="#FFEEEEEE"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:text="📊 Durchschnittsmonat"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/cardTopMonth"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="12dp"
        android:background="#FFEEEEEE"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:text="🏆 Topmonat"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/cardStreaks"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFEEEEEE"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:text="🔥 Streaks"
        android:textSize="16sp"
        android:textStyle="bold"/>

</LinearLayout>