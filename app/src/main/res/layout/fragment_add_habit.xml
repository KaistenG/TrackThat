<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editTextName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="z.B. Muay Thai"
            android:inputType="textCapSentences"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Typ"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/radioGroupVisualType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/radioVertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weekly (z.B. Sport)"
                android:checked="true"
                android:padding="8dp"/>

            <RadioButton
                android:id="@+id/radioHorizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily (z.B. Wasser trinken)"
                android:padding="8dp"/>

        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Farbe"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <GridLayout
            android:id="@+id/colorGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="6"
            android:rowCount="2"
            android:layout_marginBottom="24dp">

            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="#FF0000" android:tag="#FF0000"/>
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="#FF6600" android:tag="#FF6600"/>
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="#FFFF00" android:tag="#FFFF00"/>
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="#00FF00" android:tag="#00FF00"/>
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="#00FFFF" android:tag="#00FFFF"/>
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="#0066FF" android:tag="#0066FF"/>
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="#9900FF" android:tag="#9900FF"/>
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="#FF00FF" android:tag="#FF00FF"/>
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="#FF0099" android:tag="#FF0099"/>
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="#FFFFFF" android:tag="#FFFFFF"/>
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="#FF9900" android:tag="#FF9900"/>
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="#00FF99" android:tag="#00FF99"/>

        </GridLayout>

        <CheckBox
            android:id="@+id/checkBoxStreakable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Streak verfolgen"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/buttonSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Speichern"/>

    </LinearLayout>

</ScrollView>